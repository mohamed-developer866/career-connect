generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ── AUTH ──
model User {
  id             String   @id @default(uuid())
  fullName       String
  email          String   @unique
  password       String?
  role           Role
  isVerified     Boolean  @default(false)
  college        String?
  company        String?
  department     String?
  phone          String?
  avatarInitials String   @default("")
  placementStatus String  @default("Unplaced")
  procredits     Int      @default(0)
  
  // Company Details
  companyDescription String?
  companyWebsite    String?
  companyIndustry   String?
  companyLocation   String?   // For employer location
  
  // Student Stats
  streak           Int      @default(0)
  consistencyScore Int      @default(0)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  skills         Skill[]
  applications   JobApplication[]
  postedJobs     Job[]           @relation("postedByUser")
  messagesSent   Message[]       @relation("Sender")
  messagesRecv   Message[]       @relation("Receiver")
  courseEnrollments CourseEnrollment[]
  dailyTasks     DailyTask[]
  leaderboardEntry LeaderboardEntry?
}

model OTP {
  id        String   @id @default(uuid())
  email     String
  code      String
  purpose   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ── SKILLS ──
model Skill {
  id        String @id @default(uuid())
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  score     Int    @default(0)
  category  String @default("Technical")
  createdAt DateTime @default(now())
}

// ── JOBS ──
model Job {
  id            String           @id @default(uuid())
  title         String
  company       String
  location      String
  type          String
  salaryMin     Int
  salaryMax     Int
  description   String
  requirements  String
  skills        String
  deadline      DateTime
  maxApplicants Int              @default(50)
  collegeId     String?
  postedBy      String
  postedByUser  User             @relation("postedByUser", fields: [postedBy], references: [id])
  status        String           @default("pending")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  applications  JobApplication[]
}

model JobApplication {
  id              String   @id @default(uuid())
  jobId           String
  job             Job      @relation(fields: [jobId], references: [id])
  studentId       String
  student         User     @relation(fields: [studentId], references: [id])
  studentName     String
  studentEmail    String
  college         String
  department      String
  resume          String?   // Store file path, not the actual PDF
  resumeFileName  String?   // Original file name
  matchScore      Int      @default(0)
  status          String   @default("Applied")
  interviewStatus String?
  appliedAt       DateTime @default(now())
}
// ── MESSAGING ──
model Message {
  id         String   @id @default(uuid())
  senderId   String
  sender     User     @relation("Sender", fields: [senderId], references: [id])
  receiverId String
  receiver   User     @relation("Receiver", fields: [receiverId], references: [id])
  content    String   // Use 'content' not 'text'
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

// ── TASKS ──
model DailyTask {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskTime       String   // Changed from 'time'
  taskName       String   // Changed from 'task'
  taskType       String   // Changed from 'type'
  durationMinutes Int     // Changed from 'duration'
  isDone         Boolean  @default(false)
  taskDate       DateTime @default(now())
  createdAt      DateTime @default(now())
}

// ── ASSESSMENTS ──
model Assessment {
  id             String   @id @default(uuid())
  title          String
  company        String
  durationMin    Int
  totalQuestions Int
  createdBy      String
  createdAt      DateTime @default(now())
  questions      AssessmentQuestion[]
}

model AssessmentQuestion {
  id             String     @id @default(uuid())
  assessmentId   String
  assessment     Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  type           String
  questionText   String
  options        String?
  correctAnswer  String?
  marks          Int        @default(1)
  codingTemplate String?
  testCases      String?
}

// ── LEADERBOARD ──
model LeaderboardEntry {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credits   Int
  rank      Int      @default(0)
  trend     String   @default("stable")
  updatedAt DateTime @updatedAt
}

// ── LEARNING SYSTEM ──
model Course {
  id            String    @id @default(uuid())
  title         String
  description   String?
  category      String
  difficulty    String
  duration      String?
  totalTopics Int       @default(0)  // Change from totalTopics to totalModules
  accentColor   String    @default("#10b981")
  icon          String    @default("📚")
  thumbnailUrl  String?
  college       String?
  isFeatured    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  modules       Module[]
  enrollments   CourseEnrollment[]
}

model CourseEnrollment {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId        String
  course          Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completedTopics Int      @default(0)
  progress        Int      @default(0)
  enrolledAt      DateTime @default(now())
}

model Module {
  id          String    @id @default(uuid())
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       String
  orderIndex  Int
  duration    String
  description String?
  videoUrl    String?
  videoDuration Int?
  completedAt DateTime?
  topics      Topic[]
  createdAt   DateTime  @default(now())
}

model Topic {
  id          String   @id @default(uuid())
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  contentType String
  content     String?
  codeTemplate String?
  testCases   String?
  orderIndex  Int
  duration    String?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model UserProgress {
  id          String   @id @default(uuid())
  userId      String
  courseId    String
  moduleId    String
  topicId     String?
  completed   Boolean  @default(false)
  score       Int?
  timeSpent   Int      @default(0)
  notes       String?
  completedAt DateTime?
  createdAt   DateTime @default(now())
}

model Broadcast {
  id        String   @id @default(uuid())
  senderId  String
  text      String
  createdAt DateTime @default(now())
}

enum Role {
  STUDENT
  EMPLOYER
  COLLEGE
  ADMIN
}